{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "文书审核",
        "navigationBarBackgroundColor": "#1890ff",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#1890ff",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/upload/upload",
      "style": {
        "navigationBarTitleText": "上传文件",
        "navigationBarBackgroundColor": "#1890ff",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/preview/preview",
      "style": {
        "navigationBarTitleText": "文档预览"
      }
    },
    {
      "path": "pages/review-result/review-result",
      "style": {
        "navigationBarTitleText": "审核结果"
      }
    },
    {
      "path": "pages/report/report",
      "style": {
        "navigationBarTitleText": "审核报告"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "历史记录"
      }
    },
    {
      "path": "pages/user/user",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/invite/invite",
      "style": {
        "navigationBarTitleText": "邀请好友"
      }
    },
    {
      "path": "pages/member/member",
      "style": {
        "navigationBarTitleText": "会员中心"
      }
    },
    {
      "path": "pages/privacy/privacy",
      "style": {
        "navigationBarTitleText": "隐私协议"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "文书审核",
    "navigationBarBackgroundColor": "#1890ff",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#1890ff",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tab/home.png",
        "selectedIconPath": "static/tab/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/history/history",
        "iconPath": "static/tab/history.png",
        "selectedIconPath": "static/tab/history-active.png",
        "text": "记录"
      },
      {
        "pagePath": "pages/user/user",
        "iconPath": "static/tab/user.png",
        "selectedIconPath": "static/tab/user-active.png",
        "text": "我的"
      }
    ]
  }
}
